package database

import (
	"{{.ModulePath}}/internal/domain/{{.SnakeName}}"
	"{{.ModulePath}}/pkg/querybuilder"

	"gorm.io/gorm"
)

// {{.PascalName}}Query {{.ChineseName}}查询参数
type {{.PascalName}}Query struct {
	Name     string `form:"name"     search:"type:contains;column:name"`
	Status   *int   `form:"status"   search:"type:exact;column:status"`
	Page     int    `form:"page"`
	PageSize int    `form:"page_size"`
}

// {{.PascalName}}Repository implements {{.SnakeName}}.Repository
type {{.PascalName}}Repository struct {
	db *gorm.DB
}

// New{{.PascalName}}Repository creates a new repository
func New{{.PascalName}}Repository(database *DB) {{.SnakeName}}.Repository {
	return &{{.PascalName}}Repository{db: database.GormDB()}
}

// FindByID finds by ID
func (r *{{.PascalName}}Repository) FindByID(id uint) (*{{.SnakeName}}.{{.PascalName}}, error) {
	var model {{.PascalName}}Model
	if err := r.db.First(&model, id).Error; err != nil {
		return nil, err
	}
	return model.ToDomain(), nil
}

// List returns paginated results
func (r *{{.PascalName}}Repository) List(query *{{.PascalName}}Query) ([]*{{.SnakeName}}.{{.PascalName}}, int64, error) {
	var models []{{.PascalName}}Model
	var total int64

	db := r.db.Model(&{{.PascalName}}Model{})

	// 通过 search tag 自动构建查询条件
	db = querybuilder.Apply(db, query)

	if err := db.Count(&total).Error; err != nil {
		return nil, 0, err
	}

	page, pageSize := query.Page, query.PageSize
	if page <= 0 { page = 1 }
	if pageSize <= 0 { pageSize = 10 }
	offset := (page - 1) * pageSize

	if err := db.Offset(offset).Limit(pageSize).Order("id DESC").Find(&models).Error; err != nil {
		return nil, 0, err
	}

	entities := make([]*{{.SnakeName}}.{{.PascalName}}, len(models))
	for i := range models {
		entities[i] = models[i].ToDomain()
	}

	return entities, total, nil
}

// Save creates or updates
func (r *{{.PascalName}}Repository) Save(entity *{{.SnakeName}}.{{.PascalName}}) error {
	model := {{.PascalName}}FromDomain(entity)
	if model.ID == 0 {
		if err := r.db.Create(model).Error; err != nil {
			return err
		}
		entity.ID = model.ID
		entity.CreatedAt = model.CreatedAt
		entity.UpdatedAt = model.UpdatedAt
		return nil
	}
	return r.db.Save(model).Error
}

// Delete deletes by ID
func (r *{{.PascalName}}Repository) Delete(id uint) error {
	return r.db.Delete(&{{.PascalName}}Model{}, id).Error
}
